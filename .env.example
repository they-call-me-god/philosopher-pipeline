# NOTE: secrets are managed via Doppler (project=philosopher-pipeline, config=dev).
# Local .env is NOT used. To run: `doppler run -- python pipeline.py --now`
#
# This file exists only to document which keys the pipeline expects
# (so any teammate provisioning a fresh Doppler config knows what to set).

INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
GROQ_API_KEY=                                  # currently unused by code, reserved
